# LLM
OPENAI_API_KEY=sk-...

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=multimodal_rag

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600
CACHE_SIMILARITY_THRESHOLD=0.92

# Models
EMBEDDING_MODEL_TEXT=BAAI/bge-m3
EMBEDDING_MODEL_IMAGE=openai/clip-vit-base-patch32
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval
TOP_K_RETRIEVAL=5
TOP_K_RERANK=3

# Ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Hugging Face (optional, for faster downloads)
HF_TOKEN=hf_...

# Ollama fallback (if no OpenAI key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava:13b
